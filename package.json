{
  "type": "module",
  "private": true,
  "packageManager": "yarn@4.17.1",
  "scripts": {
    "build": "nuxi build",
    "build:analyze": "ANALYZE=true nuxi build",
    "build:visualize": "ANALYZE=true nuxi build",
    "dev:pwa": "VITE_PLUGIN_PWA=true nuxi dev",
    "dev": "portless pb-com nuxi dev",
    "generate": "nuxi generate",
    "postinstall": "nuxi prepare",
    "prepare": "npx simple-git-hooks",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "start": "node .output/server/index.mjs",
    "start:generate": "npx serve .output/public",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "vue-tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx server/db/seed.ts",
    "db:seed-cv": "tsx server/db/seed-cv.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@iconify-json/ph": "^1.2.2",
    "@libsql/client": "^0.15.11",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.4",
    "pinia": "^2.1.7",
    "posthog-js": "^1.108.3",
    "shuffle-letters": "^1.1.0",
    "valibot": "^0.25.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.4.4",
    "@iconify-json/solar": "^1.1.9",
    "@nuxt/test-utils": "^3.23.0",
    "@nuxtjs/i18n": "^10.4.1",
    "@pinia/nuxt": "^0.5.1",
    "@unocss/eslint-config": "^66.7.5",
    "@unocss/nuxt": "^66.7.5",
    "@vite-pwa/nuxt": "^0.3.5",
    "@vueuse/nuxt": "^10.7.0",
    "consola": "^3.2.3",
    "drizzle-kit": "^0.31.4",
    "eslint": "^8.56.0",
    "eslint-plugin-format": "^0.1.0",
    "eslint-ts-patch": "^8.55.0-1",
    "happy-dom": "^20.4.0",
    "lint-staged": "^16.2.7",
    "nuxt": "^3.13.1",
    "rollup-plugin-visualizer": "^6.0.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "5.5.4",
    "vitest": "^4.0.18",
    "vue-tsc": "^1.8.25"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,vue,json,tsx}": [
      "eslint"
    ]
  }
}
